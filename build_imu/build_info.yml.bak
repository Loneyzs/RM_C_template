cmake:
  application:
    configuration-dir: 'E:/zephyr_repo/RM_C_template'
    source-dir: 'E:/zephyr_repo/RM_C_template'
  board:
    name: 'rm_c'
    path:
     - 'E:/zephyr_repo/RM_C_template/boards/st/RM_C'
    qualifiers: 'stm32f407xx'
    revision: ''
  devicetree:
    bindings-dirs:
     - 'E:/zephyr_workspace/zephyr/dts/bindings'
    files:
     - 'E:/zephyr_repo/RM_C_template/boards/st/RM_C/rm_c.dts'
     - 'E:/zephyr_repo/RM_C_template/app.overlay'
    include-dirs:
     - 'E:/zephyr_repo/RM_C_template/include'
     - 'E:/zephyr_workspace/modules/hal/ambiq/dts'
     - 'E:/zephyr_workspace/modules/hal/atmel/include'
     - 'E:/zephyr_workspace/modules/hal/bouffalolab/include'
     - 'E:/zephyr_workspace/modules/hal/bouffalolab/include/zephyr'
     - 'E:/zephyr_workspace/modules/hal/gigadevice/include'
     - 'E:/zephyr_workspace/modules/hal/microchip/include'
     - 'E:/zephyr_workspace/modules/hal/microchip/dts'
     - 'E:/zephyr_workspace/modules/hal/nuvoton/dts'
     - 'E:/zephyr_workspace/modules/hal/nxp/dts'
     - 'E:/zephyr_workspace/modules/hal/stm32/dts'
     - 'E:/zephyr_workspace/modules/hal/ti/dts'
     - 'E:/zephyr_workspace/zephyr/include'
     - 'E:/zephyr_workspace/zephyr/include/zephyr'
     - 'E:/zephyr_workspace/zephyr/dts/common'
     - 'E:/zephyr_workspace/zephyr/dts/vendor'
     - 'E:/zephyr_workspace/zephyr/dts/rx'
     - 'E:/zephyr_workspace/zephyr/dts/x86'
     - 'E:/zephyr_workspace/zephyr/dts/xtensa'
     - 'E:/zephyr_workspace/zephyr/dts/sparc'
     - 'E:/zephyr_workspace/zephyr/dts/riscv'
     - 'E:/zephyr_workspace/zephyr/dts/posix'
     - 'E:/zephyr_workspace/zephyr/dts/arm64'
     - 'E:/zephyr_workspace/zephyr/dts/arm'
     - 'E:/zephyr_workspace/zephyr/dts/arc'
     - 'E:/zephyr_workspace/zephyr/dts'
    user-files:
     - 'E:/zephyr_repo/RM_C_template/app.overlay'
  kconfig:
    files:
     - 'E:/zephyr_repo/RM_C_template/boards/st/RM_C/rm_c_defconfig'
     - 'E:/zephyr_repo/RM_C_template/prj.conf'
    user-files:
     - 'E:/zephyr_repo/RM_C_template/prj.conf'
  toolchain:
    name: 'zephyr'
    path: 'E:/zephyr-sdk-1.0.1'
  zephyr:
    version: '4.4.99'
    zephyr-base: 'E:/zephyr_workspace/zephyr'
version: '0.1.0'
west:
  command: 'C:\Users\a7743\.local\bin\west build -b rm_c -d build_imu .'
  topdir: 'E:\zephyr_workspace'
  version: '1.5.0'
